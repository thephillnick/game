            P_normal_multi_attack(n,l)
        elif choice == "block":
            n = random.randint(0,17)
            block(n)
        elif choice == "heal":
            n = random.randint(0,7)
            p_heal(n)
        elif choice == "energie":
            n = random.randint(-2,5)
            if player["energy"] + n >= 0:
                player["energy"] = player["energy"] + n
            else:
                player["energy"] = 0
