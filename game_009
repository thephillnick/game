def p_normal_attack(dmg):
    total_dmg = (dmg + player["strength"]) 
    if enemie["start_block"] >= total_dmg:
        enemie["start_block"] = enemie["start_block"] - total_dmg

    else:
        enemie["enemie_hp"] = enemie["enemie_hp"] + enemie["start_block"]
        enemie["start_block"] = 0
        enemie["enemie_hp"] = enemie["enemie_hp"] - total_dmg
    print (f"{player_name} has done {total_dmg} damage")

def P_normal_multi_attack(dmg,amount):
    total_dmg = (dmg + player["strength"]) * amount
    enemie["enemie_hp"] = enemie["enemie_hp"] - total_dmg
    print (f"{player_name} has done {dmg + player["strength"]} damage {amount} times")

