def player_turn():
    draw(5 + extra_start_draw)

    while True:

        played_card = int(input("Which card do you want to play? (0 to stop): "))

        if played_card == 0:
            break
        
        played_card_card = played_card - 1
        card = p_hand_pile.pop(played_card_card)

        card_functions[card]()
        p_discard_cards.append(card)

        updated_hand()






